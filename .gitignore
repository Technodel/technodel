# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# aider AI coding tool history (contains prompt history)
.aider.input.history

# temporary / scratch HTML files
tmp-*.html

# sqlite database
*.db
*.db-journal
*.sqlite

# data processing scripts (one-off utilities, not app code)
/scripts/

# aider AI task data (prompts, context)
.aider-desk/

# database backup files
*.db.backup

# root-level temp/scratch scripts
_check-state.mjs
_run_check.cjs

# one-off utility scripts in techndodel directory
techndodel/
